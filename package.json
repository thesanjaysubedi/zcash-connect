{
  "name": "zcashconnect-mvp",
  "version": "1.0.0",
  "description": "ZcashConnect MVP — shielded payment lifecycle demo",
  "license": "MIT",
  "main": "dist/server.js",
  "scripts": {
    "dev":         "concurrently -k -n server,web -c green,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server":  "ts-node src/server.ts",
    "dev:web":     "vite --config web/vite.config.ts",
    "build":       "tsc && vite build --config web/vite.config.ts",
    "start":       "node dist/server.js",
    "test":        "vitest run",
    "test:watch":  "vitest"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.0",
    "bech32": "^2.0.0",
    "blakejs": "^1.2.1",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "qrcode": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.21",
    "vitest": "^1.6.0"
  }
}
