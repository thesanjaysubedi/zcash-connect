{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "lib":               ["ES2022", "DOM", "DOM.Iterable"],
    "jsx":               "react-jsx",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "noEmit":            true,
    "allowImportingTsExtensions": false,
    "isolatedModules":   true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
